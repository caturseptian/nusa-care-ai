# =============================================================================
# NusaCare AI - Contoh Konfigurasi Environment
# =============================================================================
# Salin file ini menjadi `.env` dan isi nilai-nilainya.
# JANGAN pernah meng-commit file `.env` ke repository.
# =============================================================================

# -----------------------------------------------------------------------------
# WAJIB - Kunci API Google Gemini
# Dapatkan kunci gratis di: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# -----------------------------------------------------------------------------
# OPSIONAL - Inferensi lokal via Ollama
# Aktifkan jika Anda menjalankan Ollama secara lokal.
# Instalasi: https://ollama.com/download
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# -----------------------------------------------------------------------------
# OPSIONAL - Pencarian web tambahan via Exa
# Daftar gratis di: https://exa.ai
# Biarkan kosong untuk menonaktifkan pencarian web.
# -----------------------------------------------------------------------------
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Konfigurasi RAG / ChromaDB
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=nusacare_kb
KNOWLEDGE_BASE_PATH=./data/knowledge_base.txt
